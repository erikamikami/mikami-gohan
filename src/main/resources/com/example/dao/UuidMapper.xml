<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dao.UuidMapper">
<select id="getUuid" resultType="String">
SELECT uuid FROM uuid where id = 1;
</select>

<select id="getToken" resultType="String">
SELECT token FROM uuid where id = 1;
</select>

<select id="updateUuid" parameterType="String" >
UPDATE uuid SET uuid = #{uuid} WHERE id = 1;
</select>

<select id="updateToken" parameterType="String" >
UPDATE uuid SET token = #{token} WHERE id = 1;
</select>

</mapper>